# ---- App ----
NODE_ENV=development
PORT=3000

# ---- Database (PostgreSQL) ----
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=checkout_user
DATABASE_PASSWORD=checkout_password
DATABASE_NAME=checkout_db
DATABASE_SSL=false

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# ---- Rate limiting ----
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
THROTTLE_LOGIN_TTL_MS=60000
THROTTLE_LOGIN_LIMIT=5

# ---- Initial admin seed (used once by the seed script, see README) ----
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123*

# ---- Payment gateway (generic names by design, see README "Design decisions") ----
PAYMENT_API_URL=https://api-sandbox.example-provider.dev/v1
PAYMENT_PUBLIC_KEY=
PAYMENT_PRIVATE_KEY=
PAYMENT_EVENTS_KEY=
PAYMENT_INTEGRITY_KEY=

# ---- Pending-transaction reconciliation (webhook fallback) ----
RECONCILE_PENDING_INTERVAL_MS=60000
